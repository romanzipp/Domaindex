APP_HOST=0.0.0.0
APP_PORT=8080
APP_SECRET=change-me-to-a-random-secret

# sqlite (default) or postgres
DB_DRIVER=sqlite
DB_DSN=data/domaindex.db

# postgres example:
# DB_DRIVER=postgres
# DB_DSN=host=db user=domain_manager password=secret dbname=domain_manager port=5432 sslmode=disable

# Apprise notification gateway (optional)
# APPRISE_URL=http://apprise:8000
# APPRISE_KEY=

# How often to refresh WHOIS data in the background (e.g. 6h, 30m)
WHOIS_REFRESH_INTERVAL=6h

# Set to false to disable new user registration
REGISTRATION_ENABLED=true
